{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Marginalia",
  "version": "0.2.10",
  "identifier": "io.marginalia.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Marginalia",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob: data:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: http://127.0.0.1:* http://localhost:*; font-src 'self' data:; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* https://api.github.com; frame-src http://127.0.0.1:* http://localhost:* blob: data:; object-src 'none'; base-uri 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/backend/**/*",
      "package/windows/*.cmd"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/marginalia": "package/linux/marginalia",
          "/usr/bin/marginalia-mcp": "package/linux/marginalia-mcp",
          "/usr/bin/marginalia-worker": "package/linux/marginalia-worker"
        }
      },
      "rpm": {
        "files": {
          "/usr/bin/marginalia": "package/linux/marginalia",
          "/usr/bin/marginalia-mcp": "package/linux/marginalia-mcp",
          "/usr/bin/marginalia-worker": "package/linux/marginalia-worker"
        }
      },
      "appimage": {
        "files": {
          "usr/bin/marginalia": "package/linux/marginalia",
          "usr/bin/marginalia-mcp": "package/linux/marginalia-mcp",
          "usr/bin/marginalia-worker": "package/linux/marginalia-worker"
        }
      }
    },
    "macOS": {
      "files": {
        "MacOS/marginalia": "package/macos/marginalia",
        "MacOS/marginalia-mcp": "package/macos/marginalia-mcp",
        "MacOS/marginalia-worker": "package/macos/marginalia-worker"
      }
    },
    "windows": {
      "nsis": {
        "installerHooks": "package/windows/nsis-hooks.nsh"
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
