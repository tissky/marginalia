APP_ENV=dev

# DB backend: sqlite or postgres
DB_BACKEND=sqlite
POSTGRES_DSN=postgresql+asyncpg://marginalia:marginalia@localhost:5432/marginalia

# Storage backend: mirror, local, or s3
#   mirror = folder-tree on disk matching the user's intent (default)
#   local  = UUID-flat object pool; faster, dedup-on, less human-friendly
#   s3     = remote object storage for multi-host deployments
# mirror/local always live under <MARGINALIA_HOME>/{library,objects}.
# Relocate everything by setting MARGINALIA_HOME, or symlink a single
# subdir if you want db on SSD and library on a big disk.
STORAGE_BACKEND=mirror

# S3 / MinIO settings (used when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=marginalia
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Task worker
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_SECONDS=2
WORKER_BATCH_SIZE=4
WORKER_LEASE_SECONDS=60
WORKER_HEARTBEAT_SECONDS=20

# ===== Agent token budgets =====
# Per-call max_tokens for plan / execute phases. Defaults sized for
# gpt-4o-class models. Bump for long-context backends — e.g. DeepSeek-V3
# can return 64K+ in one shot, so 2048 will silently truncate answers.
# AGENT_PLAN_MAX_TOKENS=1024
# AGENT_EXECUTE_MAX_TOKENS=2048

# ===== LLM defaults =====
# Per-profile overrides (LLM_<PROFILE>_*) inherit from LLM_DEFAULT_* per-field.
# PROVIDER:
#   openai            = OpenAI proper (supports strict json_schema)
#   openai-compatible = DeepSeek / Together / Groq / vllm / ollama. Same wire
#                       format; the adapter falls back to json_object + a
#                       schema-in-prompt instruction since these endpoints
#                       reject OpenAI's strict json_schema.
#   anthropic         = Anthropic Messages API
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_API_KEY=
LLM_DEFAULT_BASE_URL=
LLM_DEFAULT_MODEL=gpt-4o-mini

# ===== Per-profile LLM overrides (optional) =====
# Profiles: chat, reflect, ingest, vision.
# LLM_CHAT_PROVIDER=
# LLM_CHAT_API_KEY=
# LLM_CHAT_BASE_URL=
# LLM_CHAT_MODEL=

# LLM_REFLECT_PROVIDER=
# LLM_REFLECT_API_KEY=
# LLM_REFLECT_BASE_URL=
# LLM_REFLECT_MODEL=

# LLM_INGEST_PROVIDER=
# LLM_INGEST_API_KEY=
# LLM_INGEST_BASE_URL=
# LLM_INGEST_MODEL=

# LLM_VISION_PROVIDER=
# LLM_VISION_API_KEY=
# LLM_VISION_BASE_URL=
# LLM_VISION_MODEL=
